# Shard 01 XL run defaults — source from run_shard01_xl.sh or:  source configs/shard01_xl/run.env
#
# Override per invocation:
#   STAGES=trellis2_encode
#   OBJ_IDS_FILE=configs/shard01_xl/need_encode.txt   # or allow.txt / roster.txt
#   FORCE=1
#   PIPELINE_GPUS=0,1,2,3,4,5,6,7
#   FULL=1   — run all stages (omit STAGES)

export SHARD=01
export CONFIG=configs/shard01_xl/pipeline.yaml
export MACHINE_ENV="${MACHINE_ENV:-configs/machine/local_trellis2.env}"
export PIPELINE_GPUS="${PIPELINE_GPUS:-0,1,2,3,4,5,6,7}"

# Default object scope: preflight allow-list (2229).  For encode backfill use need_encode.txt.
export OBJ_IDS_FILE="${OBJ_IDS_FILE:-configs/shard01_xl/allow.txt}"
