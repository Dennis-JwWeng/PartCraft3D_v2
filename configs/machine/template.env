# 机器环境模板（pipeline_v3 用）。
#
# 用法：
#   cp configs/machine/template.env configs/machine/$(hostname).env
#   # 编辑下方路径，然后由 run_pipeline_v3_shard_trellis2.sh 自动 source 同名 hostname.env
# 或单次：
#   MACHINE_ENV=configs/machine/template.env bash run_pipeline_v3_shard_trellis2.sh <tag> \
#       configs/templates/pipeline_v3_bench.template.yaml

# ── Conda ──────────────────────────────────────────────────────────
CONDA_INIT=/root/miniconda3/etc/profile.d/conda.sh
CONDA_ENV_SERVER=pipeline_server
CONDA_ENV_PIPELINE=vinedresser3d

# ── Checkpoints（改成你本机绝对路径）──────────────────────────────
VLM_CKPT=/path/to/Qwen3.5-27B
EDIT_CKPT=/path/to/FLUX.2-klein-9B
# 与 YAML 配置中 ckpt_root 指向同一棵树时，与仓库内 checkpoints/ 一致即可
TRELLIS_CKPT_ROOT=/path/to/PartCraft3D/checkpoints

# ── Data I/O ──────────────────────────────────────────────────────
# DATA_DIR 指向数据集根（包含 mesh/<shard>/<obj>.npz, images/<shard>/<obj>.npz）
# OUTPUT_DIR 是产物根（每个 run 在下面创建子目录）
DATA_DIR=/path/to/data/partverse
OUTPUT_DIR=/path/to/outputs/partverse
OUTPUT_ROOT=${OUTPUT_DIR}

# ── GPU（可选，shard 脚本主要读 yaml pipeline.gpus）───────────────
VLM_GPUS="${VLM_GPUS:-0}"
EDIT_GPUS="${EDIT_GPUS:-0}"
STEP4_GPUS="${STEP4_GPUS:-0}"

# ── Optional ───────────────────────────────────────────────────────
BLENDER_PATH=/usr/local/bin/blender
ATTN_BACKEND=flash_attn
