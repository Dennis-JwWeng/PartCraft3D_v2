# 本机 (L20X×8) salvage rerun 环境。
#
# 用法：
#   MACHINE_ENV=configs/machine/local_salvage.env \
#       bash scripts/tools/run_salvage_local.sh 00 01 03 04 05 06
#
# pipeline_server 只用作 SGLang VLM 服务端；TRELLIS / Open3D / xformers 等
# 在 vinedresser3d 里。两个 env 都由 run_pipeline_v3_shard.sh 按需激活。

# ── Conda ──────────────────────────────────────────────────────────
CONDA_INIT=/mnt/zsn/miniconda3/etc/profile.d/conda.sh
CONDA_ENV_SERVER=pipeline_server
CONDA_ENV_PIPELINE=vinedresser3d

# ── Checkpoints ────────────────────────────────────────────────────
VLM_CKPT=/mnt/zsn/ckpts/Qwen3.5-27B
EDIT_CKPT=/mnt/zsn/ckpts/FLUX.2-klein-9B
TRELLIS_CKPT_ROOT=/mnt/zsn/zsn_workspace/PartCraft3D/checkpoints

# ── Data I/O ───────────────────────────────────────────────────────
DATA_DIR=/mnt/zsn/zsn_workspace/PartCraft3D/data/partverse
OUTPUT_DIR=/mnt/zsn/data/partverse/outputs/partverse
OUTPUT_ROOT=${OUTPUT_DIR}

# ── GPU layout ──────────────────────────────────────────────────────
VLM_GPUS="${VLM_GPUS:-0,1,2,3,4,5,6,7}"
EDIT_GPUS="${EDIT_GPUS:-0,1,2,3,4,5,6,7}"
STEP4_GPUS="${STEP4_GPUS:-0,1,2,3,4,5,6,7}"

# ── Misc ───────────────────────────────────────────────────────────
ATTN_BACKEND=flash_attn
# Blender NOT required for flux-salvage (preview_flux uses TRELLIS GS).
BLENDER_PATH=/usr/bin/false
