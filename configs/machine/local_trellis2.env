# 本机 (L20X×8) TRELLIS.2 pipeline_v3 环境。
#
# 用法（完整多服务管线，需要 VLM + FLUX 服务）：
#   MACHINE_ENV=configs/machine/local_trellis2.env \
#       bash run_pipeline_v3_shard_trellis2.sh shard08 <config.yaml>
#
# 最简单对象端到端（无需服务，已验证）：
#   CUDA_VISIBLE_DEVICES=0 python run_pipeline_minimal.py \
#       --shard 08 --obj-id <id> --edit-type scale --part-id 1 \
#       --instruction "..."

# ── Conda ──────────────────────────────────────────────────────────
CONDA_INIT=/mnt/zsn/miniconda3/etc/profile.d/conda.sh
# Pipeline env: TRELLIS.2 codebase deps (o_voxel / sparse / diffusers).
CONDA_ENV_PIPELINE=trellis2
# Server env: SGLang VLM + FLUX image-edit server.
CONDA_ENV_SERVER=pipeline_server

# ── Checkpoints ────────────────────────────────────────────────────
VLM_CKPT=/mnt/zsn/ckpts/Qwen3.6-27B
# Image-edit model. MUST match image_edit_server.py's default backend
# (flux-klein → Flux2KleinPipeline, 4 steps). FLUX.1-Kontext-dev is NOT klein —
# loading it under the klein 4-step path produced washed-out, under-denoised
# edits (low quality). Use the 9B FLUX.2-klein here.
EDIT_CKPT=/mnt/zsn/ckpts/FLUX.2-klein-9B
TRELLIS_CKPT_ROOT=/mnt/zsn/ckpts/TRELLIS.2-4B

# ── Data I/O ───────────────────────────────────────────────────────
DATA_DIR=/mnt/zsn/data/partverse
OUTPUT_DIR=/mnt/zsn/data/partverse/outputs/partverse
OUTPUT_ROOT=${OUTPUT_DIR}

# ── GPU layout ─────────────────────────────────────────────────────
VLM_GPUS="${VLM_GPUS:-0,1,2,3,4,5,6,7}"
EDIT_GPUS="${EDIT_GPUS:-0,1,2,3,4,5,6,7}"
STEP4_GPUS="${STEP4_GPUS:-0,1,2,3,4,5,6,7}"

# ── Misc ───────────────────────────────────────────────────────────
ATTN_BACKEND=flash_attn
# Blender 4.2.19 LTS (same build v1 used). Needed by gen_edits Mode A to
# render the segmentation (bottom) row of the VLM overview, and by
# del_mesh/preview_del. CPU Cycles solid-palette mode — no GPU/display.
BLENDER_PATH=/mnt/zsn/zsn_workspace/VoxHammer/third_party/blender-4.2.19-linux-x64/blender
